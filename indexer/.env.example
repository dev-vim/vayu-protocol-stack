# ─── RPC endpoints ────────────────────────────────────────────────────────────
# Ponder picks up PONDER_RPC_URL_{chainId}

# Local Anvil (default anvil port)
PONDER_RPC_URL_31337=http://localhost:8545

# Base Sepolia testnet
PONDER_RPC_URL_84532=

# Base mainnet
PONDER_RPC_URL_8453=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vayu_indexer

# ─── Contract addresses ───────────────────────────────────────────────────────
# VayuEpochSettlement — copy from your deploy output
VAYU_SETTLEMENT_ADDRESS=0x0000000000000000000000000000000000000000

# Block the contract was first deployed (skip zero-event history before this)
VAYU_SETTLEMENT_START_BLOCK=1

# ─── IPFS sidecar ─────────────────────────────────────────────────────────────
# Gateway used to fetch epoch blobs by CID
IPFS_GATEWAY_URL=http://localhost:8080/ipfs

# How often the sidecar polls for PENDING epochs (milliseconds)
SIDECAR_POLL_INTERVAL_MS=30000

# Max epochs processed per poll cycle
SIDECAR_BATCH_SIZE=10
