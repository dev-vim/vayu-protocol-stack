# Local dev overrides — copy to .env.local and source before running:
#   cp relay/.env.local.example relay/.env.local
#   source relay/.env.local && mvn spring-boot:run

# Verbose application logs
export RELAY_LOG_LEVEL=DEBUG
# Short epoch + fast commit worker for local testing
export RELAY_EPOCH_DURATION_SECONDS=60
export RELAY_EPOCH_COMMIT_CHECK_INTERVAL_MS=5000
export RELAY_VALIDATION_RATE_LIMIT_WINDOW_SECONDS=30
# On-chain commit — Anvil
export RELAY_CHAIN_ON_CHAIN_COMMIT_ENABLED=true
export RELAY_CHAIN_RPC_URL=http://127.0.0.1:8545
export RELAY_CHAIN_CHAIN_ID=31337
# Private key without 0x prefix — use the same Anvil account used for deployment
export RELAY_CHAIN_RELAY_PRIVATE_KEY=<RELAY_PRIVATE_KEY>
# VayuEpochSettlement address with 0x prefix from the deployment summary
export RELAY_CHAIN_SETTLEMENT_ADDRESS=<SETTLEMENT_ADDRESS>