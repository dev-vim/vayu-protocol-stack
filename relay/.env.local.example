# Local dev overrides — copy to .env.local and source before running:
#   cp relay/.env.local.example relay/.env.local
#   source relay/.env.local && mvn spring-boot:run

# Short epoch + fast commit worker for local testing
export RELAY_EPOCH_DURATION_SECONDS=60
export RELAY_EPOCH_COMMIT_CHECK_INTERVAL_MS=5000

# Verbose application logs
export RELAY_LOG_LEVEL=DEBUG
