# ─── Foundry ──────────────────────────────────────────────────────────────────
# Compiled artifacts and build cache — regenerated by `forge build`
contracts/out/
contracts/cache/
# Foundry coverage reports
contracts/lcov.info
# Deployment broadcast logs contain private keys in some setups — keep local only
contracts/broadcast/*/31337/
# Foundry snapshot file is machine-specific
contracts/.gas-snapshot
# Foundry lockfile — regenerated by forge build
contracts/foundry.lock

# ─── Node / JS / TS ───────────────────────────────────────────────────────────
node_modules/
**/node_modules/
dist/
build/
*.tsbuildinfo
.pnp
.pnp.js

# Lockfiles: commit package-lock.json / pnpm-lock.yaml, ignore yarn.lock if using pnpm
yarn.lock

# ─── Environment variables ────────────────────────────────────────────────────
# Never commit secrets — each developer copies .env.example and fills in values
.env
.env.local
.env.*.local
# Hardhat / Foundry keystore wallets
keystore/

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Cache ────────────────────────────────────────────────────────────────────
.cache/
.eslintcache
.turbo/

# ─── Relay / Indexer runtime ──────────────────────────────────────────────────
# Local IPFS repo (if running ipfs daemon locally)
relay/.ipfs/
# Ponder indexer local database
indexer/.ponder/
indexer/generated/

# ─── Temporary ────────────────────────────────────────────────────────────────
*.tmp
*.temp